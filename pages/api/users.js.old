          requestId
        });
      }
      
      console.log(`[${requestTime}] [${requestId}] Deleted user: ${username}`);
      return res.status(200).json({ 
        success: true, 
        message: 'User deleted successfully',
        timestamp: requestTime,
        requestId
      });
    } catch (error) {
      console.error(`[${requestTime}] [${requestId}] DELETE error:`, error);
      return res.status(500).json({ 
        success: false, 
        error: 'Failed to delete user',
        message: error.message,
        timestamp: requestTime,
        requestId
      });
    }
  }

  // Handle invalid methods
  res.setHeader('Allow', ['GET', 'POST', 'DELETE']);
  return res.status(405).json({ 
    success: false, 
    error: `Method ${method} not allowed`,
    timestamp: requestTime,
    requestId
  });
}

import dbConnect from '../../lib/dbConnect';
import User from '../../models/User';
import { z } from 'zod';
import mongoose from 'mongoose';

// Define a schema for user creation/retrieval
const userSchema = z.object({
  username: z.string().min(1).max(30).trim()
});

export default async function handler(req, res) {
  const { method } = req;
  const now = new Date();
  const requestTime = now.toISOString(); // ISO 8601 with milliseconds
  const requestId = Math.random().toString(36).substring(2, 15);
  
  // Set response headers for tracing and monitoring
  res.setHeader('X-Request-ID', requestId);
  res.setHeader('X-Request-Time', requestTime);
  
  console.log(`[${requestTime}] [${requestId}] User API request: ${method} ${req.url}`, {
    headers: req.headers,
    query: req.query,
    body: method === 'POST' ? '...' : undefined
  });

  // Wrap database operations in try-catch for connection errors
  try {
    // Check connection state first
    await dbConnect();
    console.log(`[${requestTime}] [${requestId}] Database connected successfully`);
    
    // Check database health
    const isMongoConnected = mongoose.connection.readyState === 1;
    if (!isMongoConnected) {
      throw new Error('MongoDB is not connected');
    }

    // Optional - verify connection can actually execute operations
    try {
      await mongoose.connection.db.admin().ping();
    } catch (pingError) {
      throw new Error(`MongoDB ping failed: ${pingError.message}`);
    }

  } catch (dbError) {
    const errorTime = new Date().toISOString();
    console.error(`[${errorTime}] [${requestId}] Database connection error:`, {
      error: dbError.message,
      code: dbError.code,
      name: dbError.name,
      connectionState: mongoose.connection.readyState
    });
    
    // Set error response headers
    res.setHeader('X-Error-Time', errorTime);
    res.setHeader('X-Error-Code', dbError.code || 'UNKNOWN');
    res.setHeader('X-Error-Type', dbError.name || 'Error');
    res.setHeader('X-DB-State', mongoose.connection.readyState.toString());
    
    return res.status(503).json({
      success: false,
      error: 'Database connection failed',
      details: {
        message: dbError.message,
        code: dbError.code,
        type: dbError.name,
        connectionState: mongoose.connection.readyState
      },
      timestamp: errorTime,
      requestId,
      retryAfter: 5
    });
  }

  switch (method) {
    // Health check
    case 'HEAD':
      try {
        await connectToDatabase();
        res.setHeader('X-Database-Status', 'Connected');
        res.setHeader('X-Response-Time', new Date().toISOString());
        return res.status(200).end();
      } catch (error) {
        res.setHeader('X-Database-Status', 'Disconnected');
        res.setHeader('X-Error-Message', error.message);
        res.setHeader('X-Error-Time', new Date().toISOString());
        return res.status(503).end();
      }
      break;
      
    // Get users
    case 'GET':
      try {
// Attempt database connection with enhanced retry logic and error handling
        console.log(`[${requestTime}] [${requestId}] Attempting database connection...`);
        
        try {
          const connection = await dbConnect();
          const connectionState = connection.connection.readyState;
          
          // Add health checks
          const isAdminEnabled = await connection.connection.db.admin().ping();
          const replicaStatus = await connection.connection.db.admin().serverStatus();
          
          if (connectionState !== 1) {
            throw new Error(`Invalid connection state: ${connectionState}`);
          }
          
          // Log successful connection
          console.log(`[${requestTime}] [${requestId}] Database connected successfully`, {
            host: connection.connection.host,
            port: connection.connection.port,
            name: connection.connection.name,
            readyState: connectionState,
            isAdminEnabled,
            isReplicaSet: replicaStatus?.repl ? 'yes' : 'no',
            version: replicaStatus?.version
          });
          
        } catch (dbError) {
          // Enhanced error logging with ISO 8601 timestamps
          const errorTime = new Date().toISOString(); // ISO 8601 with milliseconds
          const errorInfo = {
            name: dbError.name,
            code: dbError.code,
            message: dbError.message,
            stack: dbError.stack,
            connectionConfig: {
              uri: process.env.MONGODB_URI ? '***' : 'undefined',
              nodeEnv: process.env.NODE_ENV,
              mongooseVersion: mongoose.version
            }
          };
          
          // Log error details
          console.error(`[${errorTime}] [${requestId}] Database connection error:`, errorInfo);
          
          // Build error response
          const errorResponse = {
            success: false,
            error: 'Database connection error',
            timestamp: errorTime,
            requestId,
            retryable: true,
            details: {
              type: dbError.name,
              code: dbError.code || 'UNKNOWN',
              message: dbError.message
            }
          };
          
          // Handle specific error types
          switch (true) {
            case dbError.code === 'ETIMEDOUT':
            case dbError.code === 'ECONNREFUSED':
              errorResponse.error = 'Database connection timeout';
              errorResponse.details.suggestion = 'Please try again in a few moments';
              errorResponse.retryAfter = 5;
              errorResponse.statusCode = 503;
              break;
              
            case dbError.name === 'MongoServerError':
              errorResponse.error = 'Database server error';
              errorResponse.details.suggestion = 'Please check database server status';
              errorResponse.statusCode = 500;
              break;
              
            case dbError.name === 'MongooseError':
              errorResponse.error = 'Database client error';
              errorResponse.details.suggestion = 'Please verify database configuration';
              errorResponse.statusCode = 500;
              break;
              
            case dbError.message.includes('Circuit breaker'):
              errorResponse.error = 'Database temporarily unavailable';
              errorResponse.details.suggestion = 'Service is recovering, please try again later';
              errorResponse.retryAfter = 30;
              errorResponse.statusCode = 503;
              errorResponse.retryable = false;
              break;
              
            default:
              errorResponse.error = 'Unexpected database error';
              errorResponse.details.suggestion = 'Please try again or contact support';
              errorResponse.statusCode = 500;
          }
          
          // Set retry headers
          if (errorResponse.retryAfter) {
            res.setHeader('Retry-After', errorResponse.retryAfter.toString());
          }
          
          // Add correlation ID header
          res.setHeader('X-Error-Id', requestId);
          
          return res.status(errorResponse.statusCode).json(errorResponse);
        }

        // Extract and sanitize query parameters
        const username = req.query.username ? req.query.username.trim() : null;
        
        // Only log meaningful parameters
        if (username) {
          console.log(`[${requestTime}] GET params: username=${username}`);
        } else {
          console.log(`[${requestTime}] GET request for all users`);
        }
        
        let users;
        
        if (username) {
          // Validate username before querying
          if (username.length < 1 || username.length > 30) {
            return res.status(400).json({
              success: false,
              error: 'Username must be between 1 and 30 characters',
              timestamp: requestTime
            });
          }
          
          users = await User.findOne({ username });
          if (!users) {
            return res.status(404).json({
              success: false,
              error: 'User not found',
              timestamp: requestTime
            });
          }
          
          return res.status(200).json({ 
            success: true, 
            data: users,
            timestamp: requestTime
          });
        } else {
          // Get all users with optimized query
          users = await User.find({}, { username: 1, createdAt: 1, updatedAt: 1 })
            .sort({ updatedAt: -1 })
            .limit(100)
            .lean();
          
          console.log(`[${requestTime}] Retrieved ${users.length} users`);
          return res.status(200).json({ 
            success: true, 
            data: users,
            count: users.length,
            timestamp: requestTime
          });
        }
      } catch (error) {
        // Log detailed error information with ISO timestamps
        const errorTime = new Date().toISOString();
        console.error(`[${errorTime}] API Error:`, {
          route: '/api/users',
          method: 'GET',
          error: error.message,
          name: error.name,
          code: error.code,
          stack: error.stack
        });

        // Build detailed error response
        const errorResponse = {
          success: false,
          timestamp: errorTime,
          error: 'Unknown error occurred',
          details: {
            type: error.name,
            code: error.code || 'UNKNOWN',
            message: error.message
          }
        };

        // Enhance error details based on type
        if (error.name === 'MongooseError' || error.name === 'MongoError') {
          errorResponse.error = 'Database operation failed';
          errorResponse.details.suggestion = 'Please try again in a few moments';
          // Set appropriate status based on error
          if (error.code === 11000) {
            return res.status(409).json({ 
              ...errorResponse,
              error: 'Duplicate record found'
            });
          }
        } else if (error.name === 'ValidationError') {
          errorResponse.error = 'Invalid request data';
          errorResponse.details.validation = error.errors;
          return res.status(400).json(errorResponse);
        }

        // Set retry header for transient errors
        if (error.name === 'MongooseError' || error.code === 'ETIMEDOUT') {
          res.setHeader('Retry-After', '5');
        }

        return res.status(500).json(errorResponse);
      }
      break;
      
    // Create user
    case 'POST':
      try {
        // Log the raw request body for debugging
        console.log(`[${requestTime}] Request body:`, JSON.stringify(req.body));

        // Ensure req.body is an object
        const body = typeof req.body === 'string' ? JSON.parse(req.body) : req.body || {};

        // Safely validate the data with better error handling
        const validatedData = userSchema.safeParse(body);
        
        if (!validatedData.success) {
          console.error(`[${requestTime}] Validation error:`, validatedData.error.errors);
          return res.status(400).json({ 
            success: false, 
            error: validatedData.error.errors,
            timestamp: requestTime
          });
        }

        const { username } = validatedData.data;
        
        console.log(`[${requestTime}] Processing user creation: ${username}`);
        
        // Get current timestamp for all operations
        const now = new Date();
        const isoNow = now.toISOString();
        
        // Check if user already exists
        let user = await User.findOne({ username });
        let isNewUser = false;
        
        if (!user) {
          // Create a new user
          try {
            user = await User.create({ 
              username,
              createdAt: isoNow,
              updatedAt: isoNow
            });
            isNewUser = true;
            console.log(`[${requestTime}] Created new user: ${username}`);
          } catch (createError) {
            // Handle race condition where the username might have been created
            // between our check and create operation
            if (createError.code === 11000) {
              console.log(`[${requestTime}] Handling potential race condition for username: ${username}`);
              
              // Try to fetch the user again
              user = await User.findOne({ username });
              if (!user) {
                // This is truly an error case we can't recover from
                throw createError;
              }
              console.log(`[${requestTime}] Race condition detected - user already exists: ${username}`);
            } else {
              throw createError; // Rethrow if it's not a duplicate
            }
          }
        } else {
          // User exists, update the timestamp
          user.updatedAt = isoNow;
          await user.save();
          console.log(`[${requestTime}] User already exists: ${username}`);
        }
        
        return res.status(200).json({ 
          success: true, 
          data: user,
          isNewUser,
          message: isNewUser ? 'User created' : 'User already exists',
          timestamp: requestTime
        });
      } catch (error) {
        // Handle JSON parsing errors
        if (error instanceof SyntaxError && error.message.includes('JSON')) {
          console.error(`[${requestTime}] Invalid JSON in request body:`, error.message);
          return res.status(400).json({ 
            success: false, 
            error: 'Invalid JSON in request body',
            message: error.message,
            timestamp: requestTime
          });
        } else if (error instanceof z.ZodError) {
          console.error(`[${requestTime}] Validation error:`, error.errors);
          return res.status(400).json({ 
            success: false, 
            error: error.errors,
            timestamp: requestTime
          });
        } else if (error.code === 11000) {
          console.error(`[${requestTime}] Duplicate key error:`, error);
          return res.status(409).json({ 
            success: false, 
            error: 'Username already exists',
            timestamp: requestTime
          });
        } else {
          console.error(`[${requestTime}] POST error:`, error);
          return res.status(500).json({ 
            success: false, 
            error: 'Server error',
            message: error.message,
            timestamp: requestTime
          });
        }
      }
      break;
      
    // Delete user
    case 'DELETE':
      try {
        const { username } = req.query;
        
        if (!username) {
          return res.status(400).json({ 
            success: false, 
            error: 'Username is required',
            timestamp: requestTime
          });
        }
        
        // Delete user by username
        const deletedUser = await User.findOneAndDelete({ username });
        
        if (!deletedUser) {
          return res.status(404).json({ 
            success: false, 
            error: 'User not found',
            timestamp: requestTime
          });
        }
        
        console.log(`[${requestTime}] Deleted user: ${username}`);
        return res.status(200).json({ 
          success: true, 
          message: 'User deleted successfully',
          timestamp: requestTime
        });
      } catch (error) {
        console.error(`[${requestTime}] DELETE error:`, error);
        return res.status(500).json({ 
          success: false, 
          error: 'Failed to delete user',
          message: error.message,
          timestamp: requestTime
        });
      }
      break;
      
    default:
      res.setHeader('Allow', ['GET', 'POST', 'DELETE']);
      return res.status(405).json({ 
        success: false, 
        error: `Method ${method} Not Allowed`,
        timestamp: requestTime
      });
  }
  // Make sure all timestamps follow ISO 8601 format: 2025-04-13T12:34:56.789Z
}

