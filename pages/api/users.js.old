import dbConnect from '../../lib/dbConnect';
import User from '../../models/User';
import { z } from 'zod';
import mongoose from 'mongoose';

// Define a schema for user creation/retrieval
const userSchema = z.object({
  username: z.string().min(1).max(30).trim()
});

export default async function handler(req, res) {
  const { method } = req;
  const now = new Date();
  const requestTime = now.toISOString(); // ISO 8601 with milliseconds: 2025-04-13T12:34:56.789Z
  const requestId = Math.random().toString(36).substring(2, 15);
  
  // Set response headers for tracing and monitoring
  res.setHeader('X-Request-ID', requestId);
  res.setHeader('X-Request-Time', requestTime);
  
  console.log(`[${requestTime}] [${requestId}] User API request: ${method} ${req.url}`, {
    headers: req.headers,
    query: req.query,
    body: method === 'POST' ? '...' : undefined
  });

  // Initial database connection check
  try {
    await dbConnect();
    console.log(`[${requestTime}] [${requestId}] Database connected successfully`);

    // Verify connection is actually ready
    const isMongoConnected = mongoose.connection.readyState === 1;
    if (!isMongoConnected) {
      throw new Error('MongoDB is not connected');
    }

    // Verify we can actually run operations
    try {
      await mongoose.connection.db.admin().ping();
    } catch (pingError) {
      throw new Error(`MongoDB ping failed: ${pingError.message}`);
    }

  } catch (dbError) {
    // Enhanced error logging
    const errorTime = new Date().toISOString();
    console.error(`[${errorTime}] [${requestId}] Database connection error:`, {
      error: dbError.message,
      code: dbError.code,
      name: dbError.name,
      connectionState: mongoose.connection.readyState
    });
    
    // Set error response headers
    res.setHeader('X-Error-Time', errorTime);
    res.setHeader('X-Error-Code', dbError.code || 'UNKNOWN');
    res.setHeader('X-Error-Type', dbError.name || 'Error');
    res.setHeader('X-DB-State', mongoose.connection.readyState.toString());
    
    // Return detailed error response
    return res.status(503).json({
      success: false,
      error: 'Database connection failed',
      details: {
        message: dbError.message,
        code: dbError.code,
        type: dbError.name,
        connectionState: mongoose.connection.readyState
      },
      timestamp: errorTime,
      requestId,
      retryAfter: 5
    });
  }

  // Health check
  if (method === 'HEAD') {
    res.setHeader('X-Database-Status', 'Connected');
    res.setHeader('X-Response-Time', new Date().toISOString());
    return res.status(200).end();
  }

  // Get users
  if (method === 'GET') {
    try {
      // Extract and sanitize query parameters
      const username = req.query.username ? req.query.username.trim() : null;
      
      // Log query parameters
      if (username) {
        console.log(`[${requestTime}] [${requestId}] GET params: username=${username}`);
      } else {
        console.log(`[${requestTime}] [${requestId}] GET request for all users`);
      }
      
      let users;
      
      if (username) {
        // Validate username
        if (username.length < 1 || username.length > 30) {
          return res.status(400).json({
            success: false,
            error: 'Username must be between 1 and 30 characters',
            timestamp: requestTime,
            requestId
          });
        }
        
        users = await User.findOne({ username });
        if (!users) {
          return res.status(404).json({
            success: false,
            error: 'User not found',
            timestamp: requestTime,
            requestId
          });
        }
        
        return res.status(200).json({ 
          success: true, 
          data: users,
          timestamp: requestTime,
          requestId
        });
      } else {
        // Get all users with optimized query
        users = await User.find({}, { username: 1, createdAt: 1, updatedAt: 1 })
          .sort({ updatedAt: -1 })
          .limit(100)
          .lean();
        
        console.log(`[${requestTime}] [${requestId}] Retrieved ${users.length} users`);
        return res.status(200).json({ 
          success: true, 
          data: users,
          count: users.length,
          timestamp: requestTime,
          requestId
        });
      }
    } catch (error) {
      // Enhanced error logging
      const errorTime = new Date().toISOString();
      console.error(`[${errorTime}] [${requestId}] API Error:`, {
        route: '/api/users',
        method: 'GET',
        error: error.message,
        name: error.name,
        code: error.code,
        stack: error.stack
      });

      // Build detailed error response
      const errorResponse = {
        success: false,
        timestamp: errorTime,
        requestId,
        error: 'Unknown error occurred',
        details: {
          type: error.name,
          code: error.code || 'UNKNOWN',
          message: error.message
        }
      };

      // Enhance error details based on type
      if (error.name === 'MongooseError' || error.name === 'MongoError') {
        errorResponse.error = 'Database operation failed';
        errorResponse.details.suggestion = 'Please try again in a few moments';
        // Set appropriate status based on error
        if (error.code === 11000) {
          return res.status(409).json({ 
            ...errorResponse,
            error: 'Duplicate record found'
          });
        }
      } else if (error.name === 'ValidationError') {
        errorResponse.error = 'Invalid request data';
        errorResponse.details.validation = error.errors;
        return res.status(400).json(errorResponse);
      }

      // Set retry header for transient errors
      if (error.name === 'MongooseError' || error.code === 'ETIMEDOUT') {
        res.setHeader('Retry-After', '5');
      }

      return res.status(500).json(errorResponse);
    }
  }

  // Create user
  if (method === 'POST') {
    try {
      // Log raw request for debugging
      console.log(`[${requestTime}] [${requestId}] Request body:`, JSON.stringify(req.body));

      // Parse and validate request body
      const body = typeof req.body === 'string' ? JSON.parse(req.body) : req.body || {};
      const validatedData = userSchema.safeParse(body);
      
      if (!validatedData.success) {
        console.error(`[${requestTime}] [${requestId}] Validation error:`, validatedData.error.errors);
        return res.status(400).json({ 
          success: false, 
          error: validatedData.error.errors,
          timestamp: requestTime,
          requestId
        });
      }

      const { username } = validatedData.data;
      console.log(`[${requestTime}] [${requestId}] Processing user creation: ${username}`);
      
      // Use current timestamp for all operations
      const now = new Date().toISOString();
      
      // Check if user exists with race condition handling
      let user = await User.findOne({ username });
      let isNewUser = false;
      
      if (!user) {
        try {
          user = await User.create({ 
            username,
            createdAt: now,
            updatedAt: now
          });
          isNewUser = true;
          console.log(`[${requestTime}] [${requestId}] Created new user: ${username}`);
        } catch (createError) {
          // Handle race condition
          if (createError.code === 11000) {
            console.log(`[${requestTime}] [${requestId}] Race condition detected for username: ${username}`);
            user = await User.findOne({ username });
            if (!user) {
              throw createError;
            }
            console.log(`[${requestTime}] [${requestId}] User already exists: ${username}`);
          } else {
            throw createError;
          }
        }
      } else {
        // Update existing user
        user.updatedAt = now;
        await user.save();
        console.log(`[${requestTime}] [${requestId}] Updated existing user: ${username}`);
      }
      
      return res.status(200).json({ 
        success: true, 
        data: user,
        isNewUser,
        message: isNewUser ? 'User created' : 'User updated',
        timestamp: requestTime,
        requestId
      });
    } catch (error) {
      // Enhanced error handling
      if (error instanceof SyntaxError && error.message.includes('JSON')) {
        console.error(`[${requestTime}] [${requestId}] Invalid JSON in request body:`, error.message);
        return res.status(400).json({ 
          success: false, 
          error: 'Invalid JSON in request body',
          message: error.message,
          timestamp: requestTime,
          requestId
        });
      } else if (error instanceof z.ZodError) {
        console.error(`[${requestTime}] [${requestId}] Validation error:`, error.errors);
        return res.status(400).json({ 
          success: false, 
          error: error.errors,
          timestamp: requestTime,
          requestId
        });
      } else if (error.code === 11000) {
        console.error(`[${requestTime}] [${requestId}] Duplicate key error:`, error);
        return res.status(409).json({ 
          success: false, 
          error: 'Username already exists',
          timestamp: requestTime,
          requestId
        });
      } else {
        console.error(`[${requestTime}] [${requestId}] Unexpected error:`, error);
        return res.status(500).json({ 
          success: false, 
          error: 'Server error',
          message: error.message,
          timestamp: requestTime,
          requestId
        });
      }
    }
  }

  // Delete user
  if (method === 'DELETE') {
    try {
      const { username } = req.query;
      
      if (!username) {
        return res.status(400).json({ 
          success: false, 
          error: 'Username is required',
          timestamp: requestTime,
          requestId
        });
      }
      
      // Delete user by username
      const deletedUser = await User.findOneAndDelete({ username });
      
      if (!deletedUser) {
        return res.status(404).json({ 
          success: false, 
          error: 'User not found',
          timestamp: requestTime,
          requestId
        });
      }
      
      console.log(`[${requestTime}] [${requestId}] Deleted user: ${username}`);
      return res.status(200).json({ 
        success: true, 
        message: 'User deleted successfully',
        timestamp: requestTime,
        requestId
      });
    } catch (error) {
      console.error(`[${requestTime}] [${requestId}] DELETE error:`, error);
      return res.status(500).json({ 
        success: false, 
        error: 'Failed to delete user',
        message: error.message,
        timestamp: requestTime,
        requestId
      });
    }
  }

  // Handle invalid methods
  res.setHeader('Allow', ['GET', 'POST', 'DELETE']);
  return res.status(405).json({ 
    success: false, 
    error: `Method ${method} not allowed`,
    timestamp: requestTime,
    requestId
  });
}

import dbConnect from '../../lib/dbConnect';
import User from '../../models/User';
import { z } from 'zod';
import mongoose from 'mongoose';

// Define a schema for user creation/retrieval
const userSchema = z.object({
  username: z.string().min(1).max(30).trim()
});

export default async function handler(req, res) {
  const { method } = req;
  const now = new Date();
  const requestTime = now.toISOString(); // ISO 8601 with milliseconds: 2025-04-13T12:34:56.789Z
  const requestId = Math.random().toString(36).substring(2, 15);
  
  // Set response headers for tracing and monitoring
  res.setHeader('X-Request-ID', requestId);
  res.setHeader('X-Request-Time', requestTime);
  
  console.log(`[${requestTime}] [${requestId}] User API request: ${method} ${req.url}`, {
    headers: req.headers,
    query: req.query,
    body: method === 'POST' ? '...' : undefined
  });

  // Initial database connection check
  try {
    await dbConnect();
    console.log(`[${requestTime}] [${requestId}] Database connected successfully`);

    // Verify connection is actually ready
    const isMongoConnected = mongoose.connection.readyState === 1;
    if (!isMongoConnected) {
      throw new Error('MongoDB is not connected');
    }

    // Verify we can actually run operations
    try {
      await mongoose.connection.db.admin().ping();
    } catch (pingError) {
      throw new Error(`MongoDB ping failed: ${pingError.message}`);
    }

  } catch (dbError) {
    // Enhanced error logging
    const errorTime = new Date().toISOString();
    console.error(`[${errorTime}] [${requestId}] Database connection error:`, {
      error: dbError.message,
      code: dbError.code,
      name: dbError.name,
      connectionState: mongoose.connection.readyState
    });
    
    // Set error response headers
    res.setHeader('X-Error-Time', errorTime);
    res.setHeader('X-Error-Code', dbError.code || 'UNKNOWN');
    res.setHeader('X-Error-Type', dbError.name || 'Error');
    res.setHeader('X-DB-State', mongoose.connection.readyState.toString());
    
    // Return detailed error response
    return res.status(503).json({
      success: false,
      error: 'Database connection failed',
      details: {
        message: dbError.message,
        code: dbError.code,
        type: dbError.name,
        connectionState: mongoose.connection.readyState
      },
      timestamp: errorTime,
      requestId,
      retryAfter: 5
    });
  }

  // Health check
  if (method === 'HEAD') {
    res.setHeader('X-Database-Status', 'Connected');
    res.setHeader('X-Response-Time', new Date().toISOString());
    return res.status(200).end();
  }

  // Get users
  if (method === 'GET') {
    try {
      // Extract and sanitize query parameters
      const username = req.query.username ? req.query.username.trim() : null;
      
      // Log query parameters
      if (username) {
        console.log(`[${requestTime}] [${requestId}] GET params: username=${username}`);
      } else {
        console.log(`[${requestTime}] [${requestId}] GET request for all users`);
      }
      
      let users;
      
      if (username) {
        // Validate username
        if (username.length < 1 || username.length > 30) {
          return res.status(400).json({
            success: false,
            error: 'Username must be between 1 and 30 characters',
            timestamp: requestTime,
            requestId
          });
        }
        
        users = await User.findOne({ username });
        if (!users) {
          return res.status(404).json({
            success: false,
            error: 'User not found',
            timestamp: requestTime,
            requestId
          });
        }
        
        return res.status(200).json({ 
          success: true, 
          data: users,
          timestamp: requestTime,
          requestId
        });
      } else {
        // Get all users with optimized query
        users = await User.find({}, { username: 1, createdAt: 1, updatedAt: 1 })
          .sort({ updatedAt: -1 })
          .limit(100)
          .lean();
        
        console.log(`[${requestTime}] [${requestId}] Retrieved ${users.length} users`);
        return res.status(200).json({ 
          success: true, 
          data: users,
          count: users.length,
          timestamp: requestTime,
          requestId
        });
      }
    } catch (error) {
      // Enhanced error logging
      const errorTime = new Date().toISOString();
      console.error(`[${errorTime}] [${requestId}] API Error:`, {
        route: '/api/users',
        method: 'GET',
        error: error.message,
        name: error.name,
        code: error.code,
        stack: error.stack
      });

      // Build detailed error response
      const errorResponse = {
        success: false,
        timestamp: errorTime,
        requestId,
        error: 'Unknown error occurred',
        details: {
          type: error.name,
          code: error.code || 'UNKNOWN',
          message: error.message
        }
      };

      // Enhance error details based on type
      if (error.name === 'MongooseError' || error.name === 'MongoError') {
        errorResponse.error = 'Database operation failed';
        errorResponse.details.suggestion = 'Please try again in a few moments';
        // Set appropriate status based on error
        if (error.code === 11000) {
          return res.status(409).json({ 
            ...errorResponse,
            error: 'Duplicate record found'
          });
        }
      } else if (error.name === 'ValidationError') {
        errorResponse.error = 'Invalid request data';
        errorResponse.details.validation = error.errors;
        return res.status(400).json(errorResponse);
      }

      // Set retry header for transient errors
      if (error.name === 'MongooseError' || error.code === 'ETIMEDOUT') {
        res.setHeader('Retry-After', '5');
      }

      return res.status(500).json(errorResponse);
    }
  }

  // Create user
  if (method === 'POST') {
    try {
      // Log raw request for debugging
      console.log(`[${requestTime}] [${requestId}] Request body:`, JSON.stringify(req.body));

      // Parse and validate request body
      const body = typeof req.body === 'string' ? JSON.parse(req.body) : req.body || {};
      const validatedData = userSchema.safeParse(body);
      
      if (!validatedData.success) {
        console.error(`[${requestTime}] [${requestId}] Validation error:`, validatedData.error.errors);
        return res.status(400).json({ 
          success: false, 
          error: validatedData.error.errors,
          timestamp: requestTime,
          requestId
        });
      }

      const { username } = validatedData.data;
      console.log(`[${requestTime}] [${requestId}] Processing user creation: ${username}`);
      
      // Use current timestamp for all operations
      const now = new Date().toISOString();
      
      // Check if user exists with race condition handling
      let user = await User.findOne({ username });
      let isNewUser = false;
      
      if (!user) {
        try {
          user = await User.create({ 
            username,
            createdAt: now,
            updatedAt: now
          });
          isNewUser = true;
          console.log(`[${requestTime}] [${requestId}] Created new user: ${username}`);
        } catch (createError) {
          // Handle race condition
          if (createError.code === 11000) {
            console.log(`[${requestTime}] [${requestId}] Race condition detected for username: ${username}`);
            user = await User.findOne({ username });
            if (!user) {
              throw createError;
            }
            console.log(`[${requestTime}] [${requestId}] User already exists: ${username}`);
          } else {
            throw createError;
          }
        }
      } else {
        // Update existing user
        user.updatedAt = now;
        await user.save();
        console.log(`[${requestTime}] [${requestId}] Updated existing user: ${username}`);
      }
      
      return res.status(200).json({ 
        success: true, 
        data: user,
        isNewUser,
        message: isNewUser ? 'User created' : 'User updated',
        timestamp: requestTime,
        requestId
      });
    } catch (error) {
      // Enhanced error handling
      if (error instanceof SyntaxError && error.message.includes('JSON')) {
        console.error(`[${requestTime}] [${requestId}] Invalid JSON in request body:`, error.message);
        return res.status(400).json({ 
          success: false, 
          error: 'Invalid JSON in request body',
          message: error.message,
          timestamp: requestTime,
          requestId
        });
      } else if (error instanceof z.ZodError) {
        console.error(`[${requestTime}] [${requestId}] Validation error:`, error.errors);
        return res.status(400).json({ 
          success: false, 
          error: error.errors,
          timestamp: requestTime,
          requestId
        });
      } else if (error.code === 11000) {
        console.error(`[${requestTime}] [${requestId}] Duplicate key error:`, error);
        return res.status(409).json({ 
          success: false, 
          error: 'Username already exists',
          timestamp: requestTime,
          requestId
        });
      } else {
        console.error(`[${requestTime}] [${requestId}] Unexpected error:`, error);
        return res.status(500).json({ 
          success: false, 
          error: 'Server error',
          message: error.message,
          timestamp: requestTime,
          requestId
        });
      }
    }
  }

  // Delete user
  if (method === 'DELETE') {
    try {
      const { username } = req.query;
      
      if (!username) {
        return res.status(400).json({ 
          success: false, 
          error: 'Username is required',
          timestamp: requestTime,
          requestId
        });
      }
      
      // Delete user by username
      const deletedUser = await User.findOneAndDelete({ username });
      
      if (!deletedUser) {
        return res.status(404).json({ 
          success: false, 
          error: 'User not found',
          timestamp: requestTime,
          requestId
        });
      }
      
      console.log(`[${requestTime}] [${requestId}] Deleted user: ${username}`);
      return res.status(200).json({ 
        success: true, 
        message: 'User deleted successfully',
        timestamp: requestTime,
        requestId
      });
    } catch (error) {
      console.error(`[${requestTime}] [${requestId}] DELETE error:`, error);
      return res.status(500).json({ 
        success: false, 
        error: 'Failed to delete user',
        message: error.message,
        timestamp: requestTime,
        requestId
      });
    }
  }

  // Handle invalid methods
  res.setHeader('Allow', ['GET', 'POST', 'DELETE']);
  return res.status(405).json({ 
    success: false, 
    error: `Method ${method} not allowed`,
    timestamp: requestTime,
    requestId
  });
}

