export default function UsersPage() {
  const [users, setUsers] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);
  const [lastRefreshTime, setLastRefreshTime] = useState(null);

  const fetchUsers = useCallback(async () => {
    const now = new Date().toISOString(); // ISO 8601 with milliseconds
    console.log(`[${now}] Fetching users...`);
    
    try {
      setLoading(true);
      setError(null);
      
      const response = await fetch('/api/users');
      const data = await response.json();
      
      if (!data.success) {
        throw new Error(data.error || 'Failed to fetch users');
      }
      
      setUsers(data.data);
      setLastRefreshTime(new Date().toISOString()); // ISO 8601 with milliseconds
    } catch (err) {
      console.error(`[${new Date().toISOString()}] Error fetching users:`, err);
      setError(err.message);
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    fetchUsers();
  }, [fetchUsers]);

  return (
    <Layout>
