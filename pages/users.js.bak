          <Button
            className="mt-4 bg-red-600 hover:bg-red-700 text-white"
            onClick={() => {
              this.setState({ hasError: false, error: null, errorInfo: null });
              this.props.onReset?.();
            }}
          >
            Try Again
          </Button>
        </div>
      );
    }
    return this.props.children;
  }
}

