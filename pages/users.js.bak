export default function UsersPage() {
  const [users, setUsers] = useState([]);
  const [sessions, setSessions] = useState([]);
  const [loading, setLoading] = useState(true);
  const [refreshing, setRefreshing] = useState(false);
  const [error, setError] = useState(null);
  const [viewMode, setViewMode] = useState('sessions');
  const refreshIntervalRef = useRef(null);
  const fetchTimeoutRef = useRef(null);
  const lastFetchTimeRef = useRef(Date.now());

  // Constants for refresh control
  const FETCH_COOLDOWN = 5000; // 5 seconds between fetches
  const REFRESH_INTERVAL = 60000; // 1 minute refresh interval
  const REFRESH_DELAY = 500; // Delay before refresh after visibility change
  const [sessionDetails, setSessionDetails] = useState(null);
  const [remountKey, setRemountKey] = useState(Date.now()); // Force remount key
  const [requestId, setRequestId] = useState(null);
  const [lastRefreshTime, setLastRefreshTime] = useState(null);
  
  const router = useRouter();
  const { addToast } = useToast();
  const { theme: moduleTheme } = useModuleTheme();
  const { 
    sessionId,
    userId,
    status: sessionStatus,
    error: sessionError,
    isRegistered,
    formatISO,
    refreshSession
  } = useSession();

  // Debug tracking state
  const [debugInfo, setDebugInfo] = useState({
    apiCallsMade: 0,
    lastApiStatus: null,
    fetchDuration: null,
    lastError: null
  });

  // Helper function to generate a new request ID
  const generateNewRequestId = () => {
    const newRequestId = Math.random().toString(36).substring(2, 10);
    setRequestId(newRequestId);
    return newRequestId;
  };

  // Handle session status changes
  useEffect(() => {
    if (sessionError) {
      setError(`Session error: ${sessionError}`);
      addToast(`Session error: ${sessionError}. Please refresh the page.`, "error");
    }
  }, [sessionError, addToast]);
  // Fetch users data with detailed logging and error handling
  const fetchUsers = useCallback(async (showRefreshing = false) => {
    const now = Date.now();
    
    // Check if we're within the cooldown period
    if (lastFetchTimeRef.current && (now - lastFetchTimeRef.current < FETCH_COOLDOWN)) {
      console.log('Skipping fetch - within cooldown period');
      return;
    }
    
    const reqId = generateNewRequestId();
    const startTime = now;
    
    console.log(`[${reqId}] BEGIN fetchUsers`, {
      timestamp: new Date().toISOString(), // ISO 8601 with milliseconds
      showRefreshing
    });
    
    // Update loading/refreshing state based on context
    if (showRefreshing) {
      setRefreshing(true);
      addToast("Refreshing users...", "info");
    } else {
      setLoading(true);
    }
    
    try {
      // Clear any previous errors
      setError(null);
      
      console.log(`[${reqId}] Sending fetch request to: /api/users`);
      
      // Add a timeout to handle hanging requests
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 10000);
      
      const response = await fetch('/api/users', {
        signal: controller.signal,
        headers: {
          'Accept': 'application/json',
          'x-request-id': reqId
        }
      });
      
      // Clear timeout since we got a response
      clearTimeout(timeoutId);
      
      console.log(`[${reqId}] Response received, status: ${response.status}, ok: ${response.ok}`);
      
      // Update debug info
      setDebugInfo(prev => ({
        ...prev,
        apiCallsMade: prev.apiCallsMade + 1,
        lastApiStatus: response.status,
        fetchDuration: Date.now() - startTime
      }));
      
      if (!response.ok) {
        // Try to get more detailed error information
        let errorText;
        let errorData = {};
        
        try {
          // Get raw response text first for debugging
          errorText = await response.text();
          console.log(`[${reqId}] Error response raw text:`, errorText);
          
          // Try to parse as JSON if possible
          try {
            errorData = JSON.parse(errorText);
            console.log(`[${reqId}] Parsed error data:`, errorData);
          } catch (parseError) {
            console.error(`[${reqId}] Failed to parse error response as JSON:`, parseError);
          }
        } catch (textError) {
          console.error(`[${reqId}] Failed to get response text:`, textError);
        }
        
        throw new Error(errorData.error || `Failed to fetch users: HTTP ${response.status}`);
      }
      
      // Get raw response text for debugging first
      const jsonText = await response.text();
      console.log(`[${reqId}] Raw response text:`, jsonText);
      
      // Parse the data
      const data = JSON.parse(jsonText);
      console.log(`[${reqId}] Parsed data:`, data);
      
      if (data.success) {
        setUsers(data.data);
        const updateTime = new Date().toISOString(); // ISO 8601 with milliseconds
        setLastRefreshTime(updateTime);
        console.log(`[${reqId}] Successfully updated users, count:`, data.data.length);
      } else {
        throw new Error(data.error || "Failed to fetch users - unknown error");
      }
    } catch (err) {
      console.error(`[${reqId}] Error in fetchUsers:`, err);
      
      // Update debug info
      setDebugInfo(prev => ({
        ...prev,
        lastError: err.message
      }));
      
      setError(err.message);
      addToast(`Failed to load users: ${err.message}`, "error");
    } finally {
      console.log(`[${reqId}] END fetchUsers, elapsed time: ${Date.now() - startTime}ms`);
      setLoading(false);
      setRefreshing(false);
    }
  }, [addToast]);
  
  // Fetch sessions data
  const fetchSessions = useCallback(async (showRefreshing = false) => {
    if (showRefreshing) {
      setRefreshing(true);
    } else {
      setLoading(true);
    }
    
    try {
      const response = await fetch('/api/users?type=sessions');
      
      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.error || "Failed to fetch sessions");
      }
      
      const data = await response.json();
      if (data.success) {
        setSessions(data.data);
      } else {
        throw new Error(data.error || "Failed to fetch sessions");
      }
    } catch (err) {
      setError(err.message);
      addToast(err.message, "error");
    } finally {
      setLoading(false);
      setRefreshing(false);
    }
  }, [addToast]);

  // Fetch session details
  const fetchSessionDetails = useCallback(async (sesId) => {
    setLoading(true);
    
    try {
      const response = await fetch(`/api/users?type=sessions&sessionId=${encodeURIComponent(sesId)}`);
      
      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.error || "Failed to fetch session details");
      }
      
      const data = await response.json();
      if (data.success) {
        setSessionDetails(data);
      } else {
        throw new Error(data.error || "Failed to fetch session details");
      }
    } catch (err) {
      setError(err.message);
      addToast(err.message, "error");
    } finally {
      setLoading(false);
    }
  }, [addToast]);

  // Memoized refresh function to avoid recreating on every render
  const refreshData = useCallback(() => {
    console.log(`Refreshing data in ${viewMode} view`);
    
    // Check if session is active
    if (!isRegistered || !sessionId) {
      addToast("Please wait for session initialization to complete", "warning");
      refreshSession();
      return;
    }
    
    if (viewMode === 'users') {
      fetchUsers(true);
    } else if (viewMode === 'session-details' && sessionDetails) {
      fetchSessionDetails(sessionDetails.data[0].sessionId);
    } else {
      fetchSessions(true);
    }
    // Force remount to ensure fresh UI
    setRemountKey(Date.now());
  }, [viewMode, sessionDetails, isRegistered, sessionId, refreshSession, addToast, fetchUsers, fetchSessions, fetchSessionDetails]);

  // Unified data fetching and refresh effect
  useEffect(() => {
    if (!isRegistered || !sessionId) {
      console.log("Waiting for session initialization...");
      return;
    }

    const fetchData = () => {
      const now = Date.now();
      if (now - lastFetchTimeRef.current < FETCH_COOLDOWN) {
        console.log("Skipping fetch - within cooldown period");
        return;
      }

      console.log("Fetching data...", { viewMode });
      if (viewMode === 'users') {
        fetchUsers();
      } else if (viewMode === 'sessions') {
        fetchSessions();
      }
      lastFetchTimeRef.current = now;
      setLastRefreshTime(formatISO(new Date()));
    };

    // Do initial fetch with delay
    const initialFetchId = setTimeout(fetchData, REFRESH_DELAY);

    // Setup visibility change handler
    const handleVisibilityChange = () => {
      if (document.visibilityState === 'visible') {
        const now = Date.now();
        if (now - lastFetchTimeRef.current > FETCH_COOLDOWN) {
          console.log('Page became visible, refreshing data...');
          fetchData();
        }
      }
    };

    document.addEventListener('visibilitychange', handleVisibilityChange);

    // Setup refresh interval only when page is visible
    let refreshIntervalId = null;
    if (document.visibilityState === 'visible') {
      refreshIntervalId = setInterval(() => {
        const now = Date.now();
        if (now - lastFetchTimeRef.current > FETCH_COOLDOWN) {
          fetchData();
        }
      }, REFRESH_INTERVAL);
    }

    // Cleanup all timers and listeners
    return () => {
      clearTimeout(initialFetchId);
      if (refreshIntervalId) {
        clearInterval(refreshIntervalId);
      }
      document.removeEventListener('visibilitychange', handleVisibilityChange);
    };
  }, [isRegistered, sessionId, viewMode, fetchSessions, fetchUsers, formatISO]);

  // Switch between users and sessions view
  const toggleViewMode = () => {
    const newMode = viewMode === 'users' ? 'sessions' : 'users';
    setViewMode(newMode);
    
    // Clear session details if changing views
    if (newMode !== 'session-details') {
      setSessionDetails(null);
    }
  };

  // View session details
  const viewSessionDetails = (sessionId) => {
    fetchSessionDetails(sessionId);
    setViewMode('session-details');
  };

  // Back to sessions list
  const backToSessions = () => {
    setViewMode('sessions');
    setSessionDetails(null);
  };

  // Format date to ISO 8601 with milliseconds
  const formatISODate = (dateString) => {
    if (!dateString) return "N/A";
    try {
      // Format as ISO 8601 with milliseconds: 2025-04-13T12:34:56.789Z
      const date = new Date(dateString);
      if (isNaN(date.getTime())) {
        console.error("Invalid date value:", dateString);
        return "Invalid Date";
      }
      // Use the formatISO function from SessionContext
      return formatISO(date);
    } catch (err) {
      console.error("Error formatting date:", err, "Original value:", dateString);
      return "Invalid Date";
    }
  };

  // Calculate time ago
  const timeAgo = (dateString) => {
    if (!dateString) return "N/A";
    try {
      const date = new Date(dateString);
      const now = new Date();
      const diffMs = now - date;
      const diffSec = Math.floor(diffMs / 1000);
      const diffMin = Math.floor(diffSec / 60);
      const diffHour = Math.floor(diffMin / 60);
      const diffDay = Math.floor(diffHour / 24);

      if (diffDay > 0) return `${diffDay} day${diffDay > 1 ? 's' : ''} ago`;
      if (diffHour > 0) return `${diffHour} hour${diffHour > 1 ? 's' : ''} ago`;
      if (diffMin > 0) return `${diffMin} minute${diffMin > 1 ? 's' : ''} ago`;
      return `${diffSec} second${diffSec !== 1 ? 's' : ''} ago`;
    } catch (err) {
      console.error("Error calculating time ago:", err);
      return "N/A";
    }
  };

  // Calculate stats for sessions
  const sessionStats = {
    totalSessions: sessions.length,
    activeSessions: sessions.filter(session => {
      const lastActive = new Date(session.lastActive);
      const now = new Date();
      const diffMs = now - lastActive;
      return diffMs < 24 * 60 * 60 * 1000; // Active in last 24 hours
    }).length,
    userAgents: new Set(sessions.map(session => session.userAgent || 'Unknown')).size
  };

  // Calculate stats for users
  const userStats = {
    totalUsers: users.length,
    activeUsers: users.filter(user => {
      const lastActive = new Date(user.lastActive);
      const now = new Date();
      const diffMs = now - lastActive;
      return diffMs < 24 * 60 * 60 * 1000; // Active in last 24 hours
    }).length,
    totalCardViews: users.reduce((sum, user) => sum + (user.stats?.cardsViewed || 0), 0),
    totalCardLikes: users.reduce((sum, user) => sum + (user.stats?.cardsLiked || 0), 0),
    totalVotes: users.reduce((sum, user) => sum + (user.stats?.votesSubmitted || 0), 0)
  };

  // Always render the page structure with skeletons for loading states
  const renderContent = () => {
    if (sessionStatus === 'error') {
      return (
        <div className="text-center py-8">
          <div className="flex flex-col items-center justify-center">
            <FontAwesomeIcon icon={faExclamationTriangle} className="text-3xl text-red-500 mb-3" />
            <p className="text-red-500 dark:text-red-400 mb-2">Session Error: {sessionError || 'Failed to initialize session'}</p>
            <Button 
              onClick={() => window.location.reload()} 
              variant="secondary"
              className="mt-4"
            >
              Retry
            </Button>
          </div>
        </div>
      );
    }

    if (sessionStatus === 'initializing' || !sessionId) {
      return (
        <div className="space-y-4">
          <ContentSkeleton type="table" />
        </div>
      );
    }

    // Rest of the content...
    return null;
  };
  
  // Prepare static and dynamic content sections
  const renderHeader = () => (
    <motion.div
      initial={{ opacity: 0, y: -20 }}
      animate={{ opacity: 1, y: 0 }}
      className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4"
    >
      <div>
        <h1 className="text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-primary-500 to-primary-700">Users 👥</h1>
        <p className="text-gray-600 dark:text-gray-300 mt-1">
          {viewMode === 'users' 
            ? 'View and manage registered users'
            : viewMode === 'session-details'
            ? 'Session details and activity'
            : 'Browse active user sessions'
          }
        </p>
      </div>
      <div className="flex space-x-3">
        {!loading && (
          <Button
            onClick={refreshData}
            variant="primary"
            isLoading={refreshing}
            disabled={refreshing}
            className="btn-primary flex items-center"
          >
            <FontAwesomeIcon icon={faSync} className="mr-2" />
            Refresh
          </Button>
        )}
      </div>
    </motion.div>
  );

  const renderStatsSummary = () => {
    if (loading && !refreshing) {
      return (
        <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {[...Array(3)].map((_, i) => (
            <ContentSkeleton key={i} type="card" />
          ))}
        </div>
      );
    }
    return viewMode !== 'session-details' && (
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        animate={{ opacity: 1, y: 0 }}
        className="grid grid-cols-1 sm:grid-cols-3 gap-4"
      >
        {viewMode === 'users' ? (
          userStats && renderUserStats()
        ) : (
          sessionStats && renderSessionStats()
        )}
      </motion.div>
    );
  };

  const renderMainContent = () => {
    if (loading && !refreshing) {
      return <ContentSkeleton type="table" />;
    }
    if (error) {
      return renderError();
    }
    return renderContent();
  };

  // Wrap the content in an error boundary
  // Prepare page actions
  const pageActions = [
    viewMode === 'session-details' ? (
      <Button
        key="back"
        onClick={backToSessions}
        variant="secondary"
        className="btn-secondary flex items-center"
      >
        <FontAwesomeIcon icon={faUsers} className="mr-2" />
        Back to Sessions
      </Button>
    ) : (
      <Button
        key="toggle"
        onClick={toggleViewMode}
        variant="secondary"
        className="btn-secondary flex items-center"
      >
        <FontAwesomeIcon 
          icon={viewMode === 'users' ? faUsers : faUserCircle} 
          className={`mr-2 text-primary-500 dark:text-primary-400`} 
        />
        {viewMode === 'users' ? 'View Sessions' : 'View Users'}
      </Button>
    ),
    <Button
      key="refresh"
      onClick={refreshData}
      variant="primary"
      isLoading={refreshing}
      disabled={refreshing}
      className="btn-primary flex items-center"
    >
      <FontAwesomeIcon icon={faSync} className="mr-2" />
      Refresh
    </Button>
  ];

  // Prepare page stats
  const pageStats = viewMode === 'users' ? [
    { 
      label: "Total Users", 
      value: userStats.totalUsers, 
      icon: faUsers,
      color: "text-primary-500 dark:text-primary-400" 
    },
    { 
      label: "Active Users (24h)", 
      value: userStats.activeUsers, 
      icon: faUserCircle,
      color: "text-primary-600 dark:text-primary-500" 
    },
    { 
      label: "Total Card Views", 
      value: userStats.totalCardViews, 
      icon: faChartBar,
      color: "text-primary-700 dark:text-primary-600" 
    }
  ].map((stat, index) => (
    <Card key={index} className="card glass hover-card p-6">
      <div className="flex items-center justify-between">
        <div>
          <p className="text-sm text-gray-500 dark:text-gray-400">{stat.label}</p>
          <p className={`text-3xl font-bold mt-1 ${moduleTheme.textClass}`}>{stat.value}</p>
        </div>
        <FontAwesomeIcon icon={stat.icon} className={`text-3xl ${stat.color}`} />
      </div>
    </Card>
  )) : [
    { 
      label: "Total Sessions", 
      value: sessionStats.totalSessions, 
      icon: faLayerGroup,
      color: "text-primary-500 dark:text-primary-400" 
    },
    { 
      label: "Active Sessions (24h)", 
      value: sessionStats.activeSessions, 
      icon: faClock,
      color: "text-primary-600 dark:text-primary-500" 
    },
    { 
      label: "Unique Browsers", 
      value: sessionStats.userAgents, 
      icon: faFingerprint,
      color: "text-primary-700 dark:text-primary-600" 
    }
  ].map((stat, index) => (
    <Card key={index} className={`p-6 border ${moduleTheme.borderClass} hover:shadow-md transition-shadow duration-200`}>
      <div className="flex items-center justify-between">
        <div>
          <p className="text-sm text-gray-500 dark:text-gray-400">{stat.label}</p>
          <p className={`text-3xl font-bold mt-1 ${moduleTheme.textClass}`}>{stat.value}</p>
        </div>
        <FontAwesomeIcon icon={stat.icon} className={`text-3xl ${stat.color}`} />
      </div>
    </Card>
  ));

  return (
    <ErrorBoundary onReset={() => setRemountKey(Date.now())}>
      <PageWrapper key={remountKey}>
        <PageContent
          title={viewMode === 'users' ? 'Users 👥' : viewMode === 'session-details' ? 'Session Details 🔍' : 'Active Sessions 👥'}
          subtitle={viewMode === 'users' 
            ? 'View and manage registered users'
            : viewMode === 'session-details'
            ? 'Session details and activity'
            : 'Browse active user sessions'
          }
          loading={loading}
          refreshing={refreshing}
          error={error}
          actions={[
            viewMode === 'session-details' ? (
              <Button
                key="back"
                onClick={backToSessions}
                variant="secondary"
                className="btn-secondary flex items-center"
              >
                <FontAwesomeIcon icon={faUsers} className="mr-2" />
                Back to Sessions
              </Button>
            ) : (
              <Button
                key="toggle"
                onClick={toggleViewMode}
                variant="secondary"
                className="btn-secondary flex items-center"
              >
                <FontAwesomeIcon 
                  icon={viewMode === 'users' ? faUsers : faUserCircle} 
                  className={`mr-2 text-primary-500 dark:text-primary-400`} 
                />
                {viewMode === 'users' ? 'View Sessions' : 'View Users'}
              </Button>
            ),
            <Button
              key="refresh"
              onClick={refreshData}
              variant="primary"
              isLoading={refreshing}
              disabled={refreshing}
              className="btn-primary flex items-center"
            >
              <FontAwesomeIcon icon={faSync} className="mr-2" />
              Refresh
            </Button>
          ]}
          stats={viewMode === 'users' ? [
            { 
              label: "Total Users", 
              value: userStats.totalUsers, 
              icon: faUsers,
              color: "text-primary-500 dark:text-primary-400" 
            },
            { 
              label: "Active Users (24h)", 
              value: userStats.activeUsers, 
              icon: faUserCircle,
              color: "text-primary-600 dark:text-primary-500" 
            },
            { 
              label: "Total Card Views", 
              value: userStats.totalCardViews, 
              icon: faChartBar,
              color: "text-primary-700 dark:text-primary-600" 
            }
          ].map((stat, index) => (
            <Card key={index} className="card glass hover-card p-6">
              <div className="flex items-center justify-between">
                <div>
                  <p className="text-sm text-gray-500 dark:text-gray-400">{stat.label}</p>
                  <p className={`text-3xl font-bold mt-1 ${moduleTheme.textClass}`}>{stat.value}</p>
                </div>
                <FontAwesomeIcon icon={stat.icon} className={`text-3xl ${stat.color}`} />
              </div>
            </Card>
          )) : viewMode === 'sessions' ? [
            { 
              label: "Total Sessions", 
              value: sessionStats.totalSessions, 
              icon: faLayerGroup,
              color: "text-primary-500 dark:text-primary-400" 
            },
            { 
              label: "Active Sessions (24h)", 
              value: sessionStats.activeSessions, 
              icon: faClock,
              color: "text-primary-600 dark:text-primary-500" 
            },
            { 
              label: "Unique Browsers", 
              value: sessionStats.userAgents, 
              icon: faFingerprint,
              color: "text-primary-700 dark:text-primary-600" 
            }
          ].map((stat, index) => (
            <Card key={index} className={`p-6 border ${moduleTheme.borderClass} hover:shadow-md transition-shadow duration-200`}>
              <div className="flex items-center justify-between">
                <div>
                  <p className="text-sm text-gray-500 dark:text-gray-400">{stat.label}</p>
                  <p className={`text-3xl font-bold mt-1 ${moduleTheme.textClass}`}>{stat.value}</p>
                </div>
                <FontAwesomeIcon icon={stat.icon} className={`text-3xl ${stat.color}`} />
              </div>
            </Card>
          )) : null}
          module="users"
        >
          <div className="space-y-4">
            {loading && !refreshing ? (
              <ContentSkeleton type="table" />
            ) : (
              <div className="space-y-4">
                {/* Main Content */}
                <div>
          <Card className="card glass p-6">
            {/* Session Details View */}
            {viewMode === 'session-details' && (
              <div className="space-y-6">
                {loading ? (
                  <div className="flex justify-center py-8">
                    <LoadingSpinner size="lg" />
                    <span className="ml-3 text-gray-600 dark:text-gray-300">Loading session details...</span>
                  </div>
                ) : sessionDetails ? (
                  <>
                    <div className="flex justify-between items-center">
                      <h2 className={`text-xl font-semibold ${moduleTheme.textClass}`}>
                        Session Details
                      </h2>
                      <div className="flex items-center">
                        {sessionId === sessionDetails.data[0]?.sessionId && (
                          <span className="text-green-500 mr-3 text-sm font-medium">Current Session</span>
                        )}
                        <Button
                          onClick={refreshData}
                          variant="secondary"
                          isLoading={refreshing}
                          disabled={refreshing}
                className={`border-primary-200 dark:border-primary-800 hover:bg-primary-50 dark:hover:bg-primary-900/20`}
                        >
                          <FontAwesomeIcon icon={faSync} className="mr-2" />
                          Refresh
                        </Button>
                      </div>
                    </div>

                {/* Session Info */}
                <div className="bg-gray-50 dark:bg-gray-800 rounded-lg p-4">
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                      <p className="text-sm text-gray-500 dark:text-gray-400">Session ID</p>
                      <p className="font-mono text-sm">{sessionDetails.data[0]?.sessionId}</p>
                    </div>
                    <div>
                      <p className="text-sm text-gray-500 dark:text-gray-400">User ID</p>
                      <p className="font-mono text-sm">{sessionDetails.data[0]?.userId || 'None'}</p>
                    </div>
                    <div>
                      <p className="text-sm text-gray-500 dark:text-gray-400">Created At</p>
                      <p className="text-sm">{formatISODate(sessionDetails.data[0]?.createdAt)}</p>
                      <p className="text-xs text-gray-500">{timeAgo(sessionDetails.data[0]?.createdAt)}</p>
                    </div>
                    <div>
                      <p className="text-sm text-gray-500 dark:text-gray-400">Last Active</p>
                      <p className="text-sm">{formatISODate(sessionDetails.data[0]?.lastActive)}</p>
                      <p className="text-xs text-gray-500">{timeAgo(sessionDetails.data[0]?.lastActive)}</p>
                    </div>
                    <div className="md:col-span-2">
                      <p className="text-sm text-gray-500 dark:text-gray-400">User Agent</p>
                      <p className="font-mono text-xs break-all">{sessionDetails.data[0]?.userAgent || 'Unknown'}</p>
                    </div>
                  </div>
                </div>

                {/* Activity Stats */}
                <div>
                  <h3 className={`text-lg font-semibold ${moduleTheme.textClass} mb-3`}>Activity Summary</h3>
                  <div className="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <Card className={`p-4 border ${moduleTheme.borderClass}`}>
                      <div className="flex justify-between items-center">
                        <div>
                          <p className="text-sm text-gray-500 dark:text-gray-400">Total Interactions</p>
                          <p className={`text-2xl font-bold mt-1 ${moduleTheme.textClass}`}>
                            {sessionDetails.stats?.totalInteractions || 0}
                          </p>
                        </div>
                        <FontAwesomeIcon icon={faLayerGroup} className="text-2xl text-primary-500" />
                      </div>
                    </Card>
                    <Card className={`p-4 border ${moduleTheme.borderClass}`}>
                      <div className="flex justify-between items-center">
                        <div>
                          <p className="text-sm text-gray-500 dark:text-gray-400">Swipes (Left/Right)</p>
                          <p className={`text-2xl font-bold mt-1 ${moduleTheme.textClass}`}>
                            {sessionDetails.stats?.leftSwipes || 0}/{sessionDetails.stats?.rightSwipes || 0}
                          </p>
                        </div>
                        <FontAwesomeIcon icon={faThumbsUp} className="text-2xl text-primary-600" />
                      </div>
                    </Card>
                    <Card className={`p-4 border ${moduleTheme.borderClass}`}>
                      <div className="flex justify-between items-center">
                        <div>
                          <p className="text-sm text-gray-500 dark:text-gray-400">Votes Submitted</p>
                          <p className={`text-2xl font-bold mt-1 ${moduleTheme.textClass}`}>
                            {sessionDetails.stats?.votes || 0}
                          </p>
                        </div>
                        <FontAwesomeIcon icon={faChartBar} className="text-2xl text-primary-700" />
                      </div>
                    </Card>
                  </div>
                </div>

                {/* Recent Activity */}
                {sessionDetails.stats?.latestInteractions && sessionDetails.stats.latestInteractions.length > 0 && (
                  <div>
                    <h3 className={`text-lg font-semibold ${moduleTheme.textClass} mb-3`}>Recent Activity</h3>
                    <div className="overflow-x-auto">
                      <table className="w-full text-sm">
                        <thead className="bg-gray-50 dark:bg-gray-800">
                          <tr>
                            <th className="px-4 py-2 text-left">Time</th>
                            <th className="px-4 py-2 text-left">Type</th>
                            <th className="px-4 py-2 text-left">Action</th>
                            <th className="px-4 py-2 text-left">Card ID</th>
                          </tr>
                        </thead>
                        <tbody className="divide-y divide-gray-200 dark:divide-gray-700">
                          {sessionDetails.stats.latestInteractions.map((interaction, index) => (
                            <tr key={index} className="hover:bg-gray-50 dark:hover:bg-gray-800">
                              <td className="px-4 py-2">
                                <div>{timeAgo(interaction.createdAt)}</div>
                                <div className="text-xs text-gray-500">{formatISODate(interaction.createdAt)}</div>
                              </td>
                              <td className="px-4 py-2">{interaction.type}</td>
                              <td className="px-4 py-2">
                                <span className={`px-2 py-1 rounded-full text-xs font-medium ${
                                  interaction.action === 'right' 
                                    ? 'bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-100'
                                    : interaction.action === 'left'
                                    ? 'bg-red-100 text-red-800 dark:bg-red-900 dark:text-red-100'
                                    : 'bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-100'
                                }`}>
                                  {interaction.action}
                                </span>
                              </td>
                              <td className="px-4 py-2 font-mono text-xs">{interaction.cardId}</td>
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  </div>
                )}
                </>
                ) : (
                  <div className="text-center py-8">
                    <div className="flex flex-col items-center justify-center">
                      <FontAwesomeIcon icon={faExclamationTriangle} className="text-3xl text-gray-400 mb-3" />
                      <p className="text-gray-500 dark:text-gray-400 mb-2">No session details available.</p>
                      <p className="text-sm text-gray-400 dark:text-gray-500">
                        Select a valid session from the sessions list.
                      </p>
                    </div>
                  </div>
                )}
              </div>
            )}

            {/* Users List View */}
            {viewMode === 'users' && (
              <div className="space-y-4">
                <h2 className={`text-xl font-semibold ${moduleTheme.textClass} mb-4`}>Users List</h2>
                
                {users.length === 0 ? (
                  <div className="text-center py-8">
                    <div className="flex flex-col items-center justify-center">
                      <FontAwesomeIcon icon={faExclamationTriangle} className="text-3xl text-gray-400 mb-3" />
                      <p className="text-gray-500 dark:text-gray-400 mb-2">No users found in the system.</p>
                      <p className="text-sm text-gray-400 dark:text-gray-500">
                        Users are created when sessions interact with cards.
                      </p>
                      {error && (
                        <div className="mt-3 text-red-500 text-sm">{error}</div>
                      )}
                    </div>
                  </div>
                ) : (
                  <div className="overflow-x-auto">
                    <table className="w-full text-sm">
                      <thead className="bg-gray-50 dark:bg-gray-800">
                        <tr>
                          <th className="px-4 py-2 text-left">Username</th>
                          <th className="px-4 py-2 text-left">Created</th>
                          <th className="px-4 py-2 text-left">Last Active</th>
                          <th className="px-4 py-2 text-left">Cards Viewed</th>
                          <th className="px-4 py-2 text-left">Cards Liked</th>
                          <th className="px-4 py-2 text-left">Votes</th>
                        </tr>
                      </thead>
                      <tbody className="divide-y divide-gray-200 dark:divide-gray-700">
                        {users.map((user) => (
                          <tr key={user._id} className="hover:bg-gray-50 dark:hover:bg-gray-800">
                            <td className="px-4 py-3 font-medium">{user.username}</td>
                            <td className="px-4 py-3">
                              <div>{timeAgo(user.createdAt)}</div>
                              <div className="text-xs text-gray-500">{formatISODate(user.createdAt)}</div>
                            </td>
                            <td className="px-4 py-3">
                              <div>{timeAgo(user.lastActive)}</div>
                              <div className="text-xs text-gray-500">{formatISODate(user.lastActive)}</div>
                            </td>
                            <td className="px-4 py-3">{user.stats?.cardsViewed || 0}</td>
                            <td className="px-4 py-3">{user.stats?.cardsLiked || 0}</td>
                            <td className="px-4 py-3">{user.stats?.votesSubmitted || 0}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            )}

            {/* Sessions List View */}
            {viewMode === 'sessions' && (
              <div className="space-y-4">
                <h2 className={`text-xl font-semibold ${moduleTheme.textClass} mb-4`}>Active Sessions</h2>
                
                {sessions.length === 0 ? (
                  <div className="text-center py-8">
                    <div className="flex flex-col items-center justify-center">
                      <FontAwesomeIcon icon={faExclamationTriangle} className="text-3xl text-gray-400 mb-3" />
                      <p className="text-gray-500 dark:text-gray-400 mb-2">No active sessions found.</p>
                      <p className="text-sm text-gray-400 dark:text-gray-500">
                        Sessions are created when users interact with the application.
                      </p>
                      {error && (
                        <div className="mt-3 text-red-500 text-sm">{error}</div>
                      )}
                      <Button
                        onClick={refreshData}
                        variant="secondary"
                        className="mt-4"
                      >
                        <FontAwesomeIcon icon={faSync} className="mr-2" />
                        Refresh Sessions
                      </Button>
                    </div>
                  </div>
                ) : (
                  <div className="overflow-x-auto">
                    <table className="w-full text-sm">
                      <thead className="bg-gray-50 dark:bg-gray-800">
                        <tr>
                          <th className="px-4 py-2 text-left">Session ID</th>
                          <th className="px-4 py-2 text-left">Created</th>
                          <th className="px-4 py-2 text-left">Last Active</th>
                          <th className="px-4 py-2 text-left">User ID</th>
                          <th className="px-4 py-2 text-left">Browser</th>
                          <th className="px-4 py-2 text-left">Actions</th>
                        </tr>
                      </thead>
                      <tbody className="divide-y divide-gray-200 dark:divide-gray-700">
                        {sessions.map((session) => (
                          <tr key={session._id} className={`hover:bg-gray-50 dark:hover:bg-gray-800 ${
                            sessionId === session.sessionId ? 'bg-primary-50 dark:bg-primary-900/20' : ''
                          }`}>
                            <td className="px-4 py-3 font-mono text-xs">
                              {session.sessionId}
                              {sessionId === session.sessionId && (
                                <span className="ml-2 inline-block px-2 py-0.5 bg-green-100 text-green-800 dark:bg-green-900 dark:text-green-100 text-xs rounded-full">
                                  Current
                                </span>
                              )}
                            </td>
                            <td className="px-4 py-3">
                              <div>{timeAgo(session.createdAt)}</div>
                              <div className="text-xs text-gray-500">{formatISODate(session.createdAt)}</div>
                            </td>
                            <td className="px-4 py-3">
                              <div>{timeAgo(session.lastActive)}</div>
                              <div className="text-xs text-gray-500">{formatISODate(session.lastActive)}</div>
                            </td>
                            <td className="px-4 py-3 font-mono text-xs">
                              {session.userId || 'None'}
                            </td>
                            <td className="px-4 py-3 max-w-xs truncate">
                              {session.userAgent ? (
                                <span className="text-xs text-gray-500">{session.userAgent.substring(0, 40)}...</span>
                              ) : (
                                <span className="text-xs text-gray-500">Unknown</span>
                              )}
                            </td>
                            <td className="px-4 py-3">
                              <Button 
                                onClick={() => viewSessionDetails(session.sessionId)} 
                                variant="secondary"
                                size="sm"
                                className="btn-secondary text-xs"
                              >
                                View Details
                              </Button>
                            </td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
              </div>
            )}
          </Card>
                </div>
              </div>
            )}
          </div>
        </PageContent>
      </PageWrapper>
    </ErrorBoundary>
  );
 }
